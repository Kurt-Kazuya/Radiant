{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": [
    "build-essential", "autoconf", "libtool", "bison", "re2c",
    "libcurl4-openssl-dev", "libxml2-dev", "libssl-dev", "libsqlite3-dev",
    "libzip-dev", "zlib1g-dev", "libonig-dev", "libreadline-dev",
    "libgd-dev", "libicu-dev", "libpq-dev", "libbz2-dev",
    "libsodium-dev", "libargon2-dev", "libgettext-ocaml-dev", "gettext",
    "zip", "unzip"
  ],
  "packages": {
    "php": "8.4"
  },
  "steps": {
    "build": {
      "commands": [
        "...",
        "npm run build",
        "php artisan config:cache",
        "php artisan route:cache"
      ]
    }
  }
}